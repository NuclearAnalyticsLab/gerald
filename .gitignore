*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
*.Renviron

# documentation / pkgdown site
doc/*
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Development / Playground
dev/

# RStudio files
.Rproj.user/
*.Rproj
*.Ruserdata
*.Rprofile

# renv
renv.lock
renv/

# Output files, figures, etc.
data/
outputs/
src/

